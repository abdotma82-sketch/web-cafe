{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://cheap-macro-eric-cst.trycloudflare.com/api/:path*" },
    { "source": "/img/:path*", "destination": "https://cheap-macro-eric-cst.trycloudflare.com/img/:path*" },
    { "source": "/hubs/:path*", "destination": "https://cheap-macro-eric-cst.trycloudflare.com/hubs/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
